# Copy this file to .env and fill in one set of variables.
#
# Preferred: DashScope / Qwen compatible config
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
#
# Optional aliases: generic OpenAI-compatible config
# These are useful if your local setup already uses OPENAI_* names.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.4
